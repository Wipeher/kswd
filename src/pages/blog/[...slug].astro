---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;

// Compute reading time from raw markdown body
function estimateReadingTime(body: string): number {
  const stripped = body.replace(/\s+/g, ' ');
  const chineseChars = (stripped.match(/[一-鿿]/g) || []).length;
  const englishWords = stripped.replace(/[一-鿿]/g, '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(chineseChars / 300 + englishWords / 200));
}

// Get adjacent posts for prev/next navigation
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const currentIndex = allPosts.findIndex(p => p.id === post.id);

const prevPost = currentIndex < allPosts.length - 1
  ? { id: allPosts[currentIndex + 1].id, title: allPosts[currentIndex + 1].data.title }
  : null;
const nextPost = currentIndex > 0
  ? { id: allPosts[currentIndex - 1].id, title: allPosts[currentIndex - 1].data.title }
  : null;

const readingTimeMinutes = estimateReadingTime(post.body || '');

const { Content } = await render(post);
---

<BlogPost
  {...post.data}
  readingTimeMinutes={readingTimeMinutes}
  prevPost={prevPost}
  nextPost={nextPost}
>
  <Content />
</BlogPost>
