---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;

console.log('Post title:', post?.data?.title);  // 调试日志
console.log('Post body length:', post?.body?.length);

// const { Content } = await render(post);

let contentHtml = '';
try {
  const result = await render(post);
  contentHtml = result?.html || '无法渲染';
} catch (e) {
  contentHtml = `渲染错误: ${e.message}`;
}


---

<BlogPost {...post.data}>
  <div>调试信息：标题 - {post?.data?.title || '无标题'}</div>
  <div set:html={contentHtml} />
</BlogPost>


