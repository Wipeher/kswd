---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main class="max-w-3xl">
      <!-- Hero section -->
      <section class="py-16 sm:py-24 text-center">
        <div class="mx-auto mb-8 flex items-center justify-center">
          <!-- Decorative avatar circle -->
          <div class="w-24 h-24 rounded-full
                      bg-gradient-to-br from-accent to-accent-hover
                      flex items-center justify-center
                      shadow-lg ring-4 ring-[var(--color-bg)] ring-offset-4 ring-offset-[var(--color-accent-light)]">
            <span class="text-3xl font-bold text-white">K</span>
          </div>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-text tracking-tight text-balance mb-4">
          你好，欢迎来到我的博客 👋
        </h1>
        <p class="text-lg text-text-secondary max-w-lg mx-auto text-balance mb-6">
          {SITE_DESCRIPTION}
        </p>
        <span class="accent-line mx-auto"></span>
      </section>

      <!-- About snippet -->
      <section class="mb-16 text-center">
        <p class="text-text-secondary leading-relaxed max-w-prose mx-auto">
          这里记录我对技术、设计和生活的思考。喜欢探索新事物，热爱简洁优雅的代码，
          也相信持续写作是思考最好的方式。
        </p>
        <a
          href="/about"
          class="inline-flex items-center gap-1.5 mt-5 text-sm font-medium text-accent hover:text-accent-hover transition-colors duration-200"
        >
          了解更多
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </section>

      <!-- Divider -->
      <hr class="mb-12" />

      <!-- Recent posts -->
      <section>
        <div class="flex items-center gap-3 mb-8">
          <span class="accent-line" style="width: 24px;"></span>
          <h2 class="text-lg font-semibold text-text tracking-wide uppercase m-0">
            Recent Writing
          </h2>
        </div>

        <div class="space-y-4">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="group flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6
                     py-4 px-4 -mx-4 rounded-xl
                     hover:bg-[var(--color-bg-elevated)]
                     transition-colors duration-200 no-underline"
            >
              <time class="text-sm text-text-tertiary whitespace-nowrap shrink-0 sm:w-28">
                <FormattedDate date={post.data.pubDate} />
              </time>
              <div class="min-w-0">
                <h3 class="text-base font-medium text-text group-hover:text-accent
                           transition-colors duration-200 m-0 leading-snug">
                  {post.data.title}
                </h3>
                {post.data.description && (
                  <p class="text-sm text-text-secondary mt-1 line-clamp-1">
                    {post.data.description}
                  </p>
                )}
              </div>
            </a>
          ))}
        </div>

        <div class="mt-8 text-center">
          <a
            href="/blog"
            class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full
                   bg-accent text-white text-sm font-medium
                   hover:bg-accent-hover shadow-md hover:shadow-lg
                   transition-all duration-300 ease-out no-underline"
          >
            阅读更多文章
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
      </section>
    </main>

    <Footer />
    <ScrollToTop />
  </body>
</html>
