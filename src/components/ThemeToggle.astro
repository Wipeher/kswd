---
// ThemeToggle.astro — Sun/Moon toggle with localStorage persistence
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle dark mode"
  class="relative flex items-center justify-center w-10 h-10 rounded-full
         text-text-secondary hover:text-accent hover:bg-accent-light
         transition-all duration-300 ease-out cursor-pointer
         border-0 bg-transparent"
>
  <!-- Sun icon (visible in dark mode) -->
  <svg
    id="sun-icon"
    class="w-5 h-5 transition-transform duration-500 ease-out
           rotate-90 scale-0 absolute"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="5" />
    <line x1="12" y1="1" x2="12" y2="3" />
    <line x1="12" y1="21" x2="12" y2="23" />
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
    <line x1="1" y1="12" x2="3" y2="12" />
    <line x1="21" y1="12" x2="23" y2="12" />
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
  </svg>
  <!-- Moon icon (visible in light mode) -->
  <svg
    id="moon-icon"
    class="w-5 h-5 transition-transform duration-500 ease-out
           rotate-0 scale-100"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script>
  function setTheme(theme: string) {
    if (theme === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
    } else {
      document.documentElement.removeAttribute('data-theme');
    }
    localStorage.setItem('theme', theme);
  }

  function getTheme(): string {
    const stored = localStorage.getItem('theme');
    if (stored) return stored;
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function updateIcons(theme: string) {
    const sun = document.getElementById('sun-icon');
    const moon = document.getElementById('moon-icon');
    if (!sun || !moon) return;
    if (theme === 'dark') {
      sun.classList.remove('rotate-90', 'scale-0');
      sun.classList.add('rotate-0', 'scale-100');
      moon.classList.remove('rotate-0', 'scale-100');
      moon.classList.add('rotate-90', 'scale-0');
    } else {
      sun.classList.remove('rotate-0', 'scale-100');
      sun.classList.add('rotate-90', 'scale-0');
      moon.classList.remove('rotate-90', 'scale-0');
      moon.classList.add('rotate-0', 'scale-100');
    }
  }

  // Initialize on load
  const current = getTheme();
  updateIcons(current);

  // Toggle on click
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const current = getTheme();
    const next = current === 'dark' ? 'light' : 'dark';
    setTheme(next);
    updateIcons(next);
  });

  // Listen for OS theme changes (only when user hasn't set a preference)
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('theme')) {
      const next = e.matches ? 'dark' : 'light';
      setTheme(next);
      updateIcons(next);
    }
  });
</script>
