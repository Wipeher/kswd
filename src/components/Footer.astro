---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const today = new Date();
---

<footer class="border-t border-border bg-[var(--color-bg-elevated)]">
  <div class="max-w-5xl mx-auto px-4 py-12">
    <!-- Main footer grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-8">
      <!-- Column 1: Brand -->
      <div>
        <h3 class="text-base font-bold text-text mb-2">{SITE_TITLE}</h3>
        <p class="text-sm text-text-secondary leading-relaxed">{SITE_DESCRIPTION}</p>
      </div>

      <!-- Column 2: Navigation -->
      <div>
        <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-widest mb-3">导航</h4>
        <nav class="flex flex-col gap-2">
          <a href="/" class="text-sm text-text-secondary hover:text-accent transition-colors duration-200">Home</a>
          <a href="/blog" class="text-sm text-text-secondary hover:text-accent transition-colors duration-200">Blog</a>
          <a href="/about" class="text-sm text-text-secondary hover:text-accent transition-colors duration-200">About</a>
          <a href="/rss.xml" class="text-sm text-text-secondary hover:text-accent transition-colors duration-200">RSS</a>
        </nav>
      </div>

      <!-- Column 3: Social -->
      <div>
        <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-widest mb-3">社交</h4>
        <div class="flex flex-col gap-2">
          <a href="https://github.com" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent transition-colors duration-200">
            <svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16" fill="currentColor"
                 ><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
            GitHub
          </a>
          <a href="/rss.xml"
             class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent transition-colors duration-200">
            <svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                 ><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
            RSS Feed
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-border pt-6 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-text-tertiary">
        &copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.
      </p>
      <p class="text-xs text-text-tertiary">
        Built with <a href="https://astro.build" class="text-accent hover:text-accent-hover">Astro</a>
      </p>
    </div>
  </div>
</footer>
