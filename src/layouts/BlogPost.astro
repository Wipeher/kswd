---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ReadingTime from '../components/ReadingTime.astro';
import ScrollToTop from '../components/ScrollToTop.astro';

type Props = CollectionEntry<'blog'>['data'] & {
  readingTimeMinutes?: number;
  prevPost?: { id: string; title: string } | null;
  nextPost?: { id: string; title: string } | null;
};

const {
  title, description, pubDate, updatedDate, heroImage,
  readingTimeMinutes, prevPost, nextPost,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} image={heroImage} />
    <style>
      main {
        width: 100%;
        max-width: 100%;
        margin: 0;
        padding: 0;
      }
    </style>
  </head>
  <body>
    <Header />

    <main>
      <article>
        <!-- Hero image area -->
        <div class="w-full overflow-hidden bg-[var(--color-bg-elevated)]">
          {heroImage ? (
            <Image
              src={heroImage}
              alt=""
              width={1200}
              height={500}
              class="w-full object-cover max-h-[420px] block"
            />
          ) : (
            <div class="w-full h-48 sm:h-64 flex items-center justify-center
                        bg-gradient-to-br from-accent-light via-[var(--color-bg-elevated)] to-[var(--color-surface)]">
              <svg class="w-16 h-16 text-accent/25" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/>
              </svg>
            </div>
          )}
        </div>

        <!-- Article header -->
        <div class="max-w-3xl mx-auto px-4 sm:px-6 pt-12 pb-4 text-center">
          <time class="text-sm text-accent font-medium uppercase tracking-wider">
            <FormattedDate date={pubDate} />
          </time>
          <h1 class="text-3xl sm:text-4xl font-bold text-text tracking-tight mt-3 mb-4 text-balance leading-tight">
            {title}
          </h1>
          {readingTimeMinutes !== undefined && (
            <div class="mb-6">
              <ReadingTime minutes={readingTimeMinutes} lang="zh" />
            </div>
          )}
          {updatedDate && (
            <p class="text-xs text-text-tertiary italic mb-4">
              最后更新于 <FormattedDate date={updatedDate} />
            </p>
          )}
          <span class="accent-line mx-auto mt-6"></span>
        </div>

        <!-- Article body -->
        <div class="prose max-w-3xl mx-auto px-4 sm:px-6 py-8">
          <slot />
        </div>

        <!-- Post navigation -->
        <nav class="max-w-3xl mx-auto px-4 sm:px-6 py-8 border-t border-border mt-8">
          <div class="grid grid-cols-2 gap-4">
            {prevPost ? (
              <a
                href={`/blog/${prevPost.id}/`}
                class="group flex flex-col p-4 -ml-4 rounded-xl
                       hover:bg-[var(--color-bg-elevated)]
                       transition-colors duration-200 no-underline col-start-1"
              >
                <span class="text-xs text-text-tertiary uppercase tracking-wider mb-1">上一篇</span>
                <span class="text-sm font-medium text-text group-hover:text-accent transition-colors duration-200 line-clamp-1">
                  {prevPost.title}
                </span>
              </a>
            ) : <div />}
            {nextPost ? (
              <a
                href={`/blog/${nextPost.id}/`}
                class="group flex flex-col items-end p-4 -mr-4 rounded-xl
                       hover:bg-[var(--color-bg-elevated)]
                       transition-colors duration-200 no-underline col-start-2 text-right"
              >
                <span class="text-xs text-text-tertiary uppercase tracking-wider mb-1">下一篇</span>
                <span class="text-sm font-medium text-text group-hover:text-accent transition-colors duration-200 line-clamp-1">
                  {nextPost.title}
                </span>
              </a>
            ) : <div />}
          </div>

          <div class="text-center mt-6">
            <a
              href="/blog"
              class="inline-flex items-center gap-1.5 text-sm text-text-secondary hover:text-accent transition-colors duration-200"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
              </svg>
              返回文章列表
            </a>
          </div>
        </nav>
      </article>
    </main>

    <Footer />
    <ScrollToTop />
  </body>
</html>
